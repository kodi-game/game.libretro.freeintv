<?xml version="1.0" encoding="UTF-8"?>
<addon id="game.libretro.freeintv"
		name="Mattel - Intellivision (FreeIntv)"
		version="1.2.0.36"
		provider-name="David Richardson">
	<requires>
		<import addon="game.libretro" version="1.0.0"/>
	</requires>
	<extension point="kodi.gameclient"
			library_@PLATFORM@="@LIBRARY_FILENAME@">
		<platforms></platforms>
		<extensions>int|bin|rom</extensions>
		<supports_vfs>false</supports_vfs>
		<supports_standalone>false</supports_standalone>
		<supports_disc_control>false</supports_disc_control>
		<requires_opengl>false</requires_opengl>
	</extension>
	<extension point="xbmc.addon.metadata">
		<license>GPLv3</license>
		<platform>@PLATFORM@</platform>
		<source>https://github.com/kodi-game/game.libretro.freeintv</source>
		<assets>
			<icon>resources/icon.png</icon>
		</assets>
		<summary lang="da_DK">Mattel - Intellivision (FreeIntv)</summary>
		<summary lang="en_GB">Mattel - Intellivision (FreeIntv)</summary>
		<summary lang="es_ES">Mattel - Intellivision (FreeIntv)</summary>
		<summary lang="ga">Mattel - Intellivision (FreeIntv)</summary>
